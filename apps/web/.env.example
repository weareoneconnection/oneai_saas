# OneAI SaaS Web environment

# Core
NEXT_PUBLIC_SITE_URL=https://oneai-saas-web-production.up.railway.app
NEXTAUTH_URL=https://oneai-saas-web-production.up.railway.app
NEXTAUTH_SECRET=replace_with_strong_random_secret
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# OneAI API
ONEAI_API_BASE_URL=https://oneai-saas-api-production.up.railway.app
ONEAI_API_KEY=replace_with_customer_or_console_api_key
ONEAI_ADMIN_API_KEY=replace_with_api_admin_key
ONEAI_ADMIN_KEY=

# Console password login
ONEAI_CONSOLE_USER_EMAIL=operator@example.com
ONEAI_CONSOLE_PASSWORD=replace_with_console_password

# Auth providers, optional
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
EMAIL_SERVER=
EMAIL_FROM=

# Stripe public price IDs
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_replace_pro
NEXT_PUBLIC_STRIPE_PRICE_TEAM=price_replace_team
