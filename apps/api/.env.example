# OneAI SaaS API environment

# Core
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
PORT=4000
APP_URL=https://oneai-saas-web-production.up.railway.app

# Auth and admin
ADMIN_API_KEY=replace_with_strong_admin_key
ONEAI_ADMIN_API_KEY=replace_with_same_admin_key_if_needed
ONEAI_ADMIN_KEY=replace_with_same_admin_key_if_needed
API_KEYS=replace_with_bootstrap_customer_key_if_needed

# Redis / rate limiting
REDIS_URL=redis://USER:PASSWORD@HOST:PORT

# Default LLM routing
OPENAI_API_KEY=sk-replace
ONEAI_DEFAULT_PROVIDER=openai
ONEAI_DEFAULT_MODEL=gpt-5.2
ONEAI_LLM_AUTO_MODE=
ONEAI_LLM_AUTO_FALLBACKS=
ONEAI_LLM_AUTO_FALLBACK_LIMIT=2
ONEAI_ALLOWED_LLM_PROVIDERS=
ONEAI_ALLOWED_LLM_MODELS=

