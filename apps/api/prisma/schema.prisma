generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// * =========================
///  * NextAuth models (Prisma Adapter standard)
///  * =========================
model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  accounts      Account[]
  memberships   Membership[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// * =========================
///  * SaaS: Organizations / Memberships
///  * =========================
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  apiKeys     ApiKey[]
  requests    Request[]
  usageDaily  UsageDaily[]

  // ✅ FIX: 反向关系字段（OrgBilling.org 的 opposite）
  billing OrgBilling?
}

model Membership {
  id        String       @id @default(cuid())
  orgId     String
  userId    String
  role      OrgRole      @default(MEMBER)
  createdAt DateTime     @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
}

/// * =========================
///  * SaaS: API Keys (store hash only)
///  * =========================
model ApiKey {
  id               String       @id @default(cuid())
  name             String
  keyHash          String       @unique
  createdAt        DateTime     @default(now())
  allowedIps       String[]     @default([])
  monthlyBudgetUsd Float?
  orgId            String
  prefix           String
  rateLimitRpm     Int?
  revokedAt        DateTime?
  scopes           String[]     @default([])
  status           ApiKeyStatus @default(ACTIVE)
  updatedAt        DateTime     @updatedAt
  lastUsedAt       DateTime?
  userEmail        String       @db.VarChar(255)
  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  requests         Request[]
  usageDaily       UsageDaily[]

  @@index([orgId, status])
}

/// * =========================
///  * Core: Request log (existing)
///  * You can adapt fields to match your current code.
///  * =========================
model Request {
  id               String        @id @default(cuid())
  requestId        String        @unique @default(cuid())
  createdAt        DateTime      @default(now())
  task             String
  success          Boolean       @default(true)
  attempts         Int           @default(1)
  error            String?
  provider         String        @default("unknown")
  model            String
  promptTokens     Int           @default(0)
  completionTokens Int           @default(0)
  totalTokens      Int           @default(0)
  apiKeyId         String?
  estimatedCostUsd Float         @default(0)
  idempotencyKey   String?
  inputJson        Json?
  latencyMs        Int?
  orgId            String?
  outputJson       Json?
  apiKey           ApiKey?       @relation(fields: [apiKeyId], references: [id])
  org              Organization? @relation(fields: [orgId], references: [id])

  @@index([createdAt])
  @@index([orgId, createdAt])
  @@index([apiKeyId, createdAt])
  @@index([provider, model])
  @@unique([orgId, apiKeyId, idempotencyKey])
}

/// * =========================
///  * Aggregates for dashboard + billing
///  * =========================
model UsageDaily {
  id               String       @id @default(cuid())
  day              String
  orgId            String
  apiKeyId         String?
  task             String
  provider         String       @default("unknown")
  model            String
  requestCount     Int          @default(0)
  promptTokens     Int          @default(0)
  completionTokens Int          @default(0)
  totalTokens      Int          @default(0)
  costUsd          Float        @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  apiKey           ApiKey?      @relation(fields: [apiKeyId], references: [id])
  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([day, orgId, apiKeyId, task, provider, model])
  @@index([orgId, day])
  @@index([provider, model])
}

model OrgBilling {
  id    String @id @default(cuid())
  orgId String @unique

  stripeCustomerId String?   @unique
  stripeSubId      String?   @unique
  plan             String    @default("free")
  status           String    @default("inactive") // active, trialing, canceled...
  currentPeriodEnd DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([plan])
  @@index([status])
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ApiKeyStatus {
  ACTIVE
  SUSPENDED
  REVOKED
}
