{
  "$id": "oneclawExecuteV3",
  "type": "object",
  "additionalProperties": false,
  "required": ["reply", "shouldExecute", "oneclawTask"],
  "properties": {
    "reply": {
      "type": "string",
      "minLength": 1,
      "maxLength": 5000
    },
    "shouldExecute": {
      "type": "boolean"
    },
    "oneclawTask": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["taskName", "steps"],
          "properties": {
            "taskName": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            "steps": {
              "type": "array",
              "minItems": 1,
              "maxItems": 30,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "action", "input"],
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^[a-zA-Z0-9_-]{2,80}$"
                  },
                  "action": {
                    "type": "string",
                    "enum": [
                      "content.generate",
                      "content.transform",
                      "api.request",
                      "browser.open",
                      "browser.screenshot",
                      "file.read",
                      "file.write",
                      "message.send",
                      "social.post",
                      "result.compose"
                    ]
                  },
                  "input": {
                    "type": "object",
                    "additionalProperties": true
                  },
                  "dependsOn": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "pattern": "^[a-zA-Z0-9_-]{2,80}$"
                    },
                    "uniqueItems": true
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}