{
  "$id": "identityOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["displayName", "role", "bio", "strengths", "goals", "nextActions", "tags"],
  "properties": {
    "displayName": { "type": "string", "minLength": 1, "maxLength": 80 },
    "role": { "type": "string", "minLength": 2, "maxLength": 60 },
    "bio": { "type": "string", "minLength": 10, "maxLength": 400 },

    "strengths": {
      "type": "array",
      "minItems": 2,
      "maxItems": 6,
      "items": { "type": "string", "minLength": 2, "maxLength": 60 }
    },
    "goals": {
      "type": "array",
      "minItems": 2,
      "maxItems": 6,
      "items": { "type": "string", "minLength": 2, "maxLength": 80 }
    },
    "nextActions": {
      "type": "array",
      "minItems": 2,
      "maxItems": 6,
      "items": { "type": "string", "minLength": 2, "maxLength": 120 }
    },
    "tags": {
      "type": "array",
      "minItems": 2,
      "maxItems": 10,
      "items": { "type": "string", "minLength": 2, "maxLength": 24 }
    }
  }
}