{
  "$id": "missionOsOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mission_title",
    "objective",
    "steps",
    "proof",
    "reward_structure",
    "ranking_model",
    "anti_sybil_mechanism",
    "growth",
    "economics",
    "risk",
    "recommendedCopy"
  ],
  "properties": {
    "mission_title": { "type": "string" },
    "objective": { "type": "string" },

    "steps": {
      "type": "array",
      "minItems": 3,
      "maxItems": 10,
      "items": { "type": "string" }
    },

    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proofType", "proofInstructions", "submissionFormat"],
      "properties": {
        "proofType": { "type": "string", "enum": ["SIGN_MESSAGE", "SCREENSHOT", "LINK", "TEXT"] },
        "proofInstructions": { "type": "string" },
        "submissionFormat": { "type": "string" }
      }
    },

    "reward_structure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["top_reward", "participation_reward", "scoring", "budgetCap"],
      "properties": {
        "top_reward": { "type": "string" },
        "participation_reward": { "type": "string" },
        "scoring": {
          "type": "array",
          "minItems": 2,
          "maxItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["action", "points"],
            "properties": {
              "action": { "type": "string" },
              "points": { "type": "integer", "minimum": 1, "maximum": 1000 }
            }
          }
        },
        "budgetCap": {
          "type": "object",
          "additionalProperties": false,
          "required": ["currency", "maxParticipants", "maxTotalReward"],
          "properties": {
            "currency": { "type": "string" },
            "maxParticipants": { "type": "integer", "minimum": 1, "maximum": 1000000 },
            "maxTotalReward": { "type": "number", "minimum": 0 }
          }
        }
      }
    },

    "ranking_model": { "type": "string" },

    "anti_sybil_mechanism": { "type": "string" },

    "growth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["viralCoefficientEstimate", "shareHooks", "referralLoop"],
      "properties": {
        "viralCoefficientEstimate": { "type": "number", "minimum": 0, "maximum": 10 },
        "shareHooks": {
          "type": "array",
          "minItems": 2,
          "maxItems": 6,
          "items": { "type": "string" }
        },
        "referralLoop": { "type": "string" }
      }
    },

    "economics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["costDrivers", "expectedROI", "sustainabilityNotes"],
      "properties": {
        "costDrivers": {
          "type": "array",
          "minItems": 2,
          "maxItems": 6,
          "items": { "type": "string" }
        },
        "expectedROI": { "type": "string" },
        "sustainabilityNotes": { "type": "string" }
      }
    },

    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["abuseVectors", "mitigations", "edgeCases"],
      "properties": {
        "abuseVectors": {
          "type": "array",
          "minItems": 2,
          "maxItems": 6,
          "items": { "type": "string" }
        },
        "mitigations": {
          "type": "array",
          "minItems": 2,
          "maxItems": 8,
          "items": { "type": "string" }
        },
        "edgeCases": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "items": { "type": "string" }
        }
      }
    },

    "recommendedCopy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tweet_zh", "tweet_en", "hashtags", "cta"],
      "properties": {
        "tweet_zh": { "type": "string" },
        "tweet_en": { "type": "string" },
        "hashtags": {
          "type": "array",
          "minItems": 3,
          "maxItems": 8,
          "items": { "type": "string" }
        },
        "cta": { "type": "string" }
      }
    }
  }
}