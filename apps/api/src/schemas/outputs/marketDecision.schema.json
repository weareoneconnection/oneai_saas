{
  "$id": "marketDecisionOutput",
  "type": "object",
  "required": [
    "decision",
    "executionPlan",
    "riskCheck",
    "rationale",
    "alternatives",
    "insights"
  ],
  "additionalProperties": false,
  "properties": {
    "decision": {
      "type": "object",
      "required": ["action", "approved", "confidence", "urgency", "reason"],
      "additionalProperties": false,
      "properties": {
        "action": {
          "type": "string",
          "enum": ["BUY", "SELL", "WAIT"]
        },
        "approved": {
          "type": "boolean"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "urgency": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "reason": {
          "type": "string",
          "minLength": 5
        }
      }
    },

    "executionPlan": {
      "type": "object",
      "required": [
        "symbol",
        "side",
        "orderType",
        "sizeMode",
        "sizeValue",
        "entryZone",
        "stopLoss",
        "takeProfit",
        "timeHorizon"
      ],
      "additionalProperties": false,
      "properties": {
        "symbol": {
          "type": "string"
        },
        "side": {
          "type": "string",
          "enum": ["BUY", "SELL", "NONE"]
        },
        "orderType": {
          "type": "string",
          "enum": ["MARKET", "LIMIT", "NONE"]
        },
        "sizeMode": {
          "type": "string",
          "enum": ["quote", "base", "none"]
        },
        "sizeValue": {
          "type": "number",
          "minimum": 0
        },
        "entryZone": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "number" }
        },
        "stopLoss": {
          "type": "number",
          "minimum": 0
        },
        "takeProfit": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "number" }
        },
        "timeHorizon": {
          "type": "string",
          "enum": ["scalp", "intraday", "swing", "none"]
        }
      }
    },

    "riskCheck": {
      "type": "object",
      "required": [
        "status",
        "maxRiskAllowed",
        "estimatedRisk",
        "blockingReason",
        "warnings"
      ],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "caution"]
        },
        "maxRiskAllowed": {
          "type": "number",
          "minimum": 0
        },
        "estimatedRisk": {
          "type": "number",
          "minimum": 0
        },
        "blockingReason": {
          "type": "string"
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "rationale": {
      "type": "object",
      "required": [
        "marketAlignment",
        "setupQuality",
        "timing",
        "positioning"
      ],
      "additionalProperties": false,
      "properties": {
        "marketAlignment": { "type": "string" },
        "setupQuality": {
          "type": "string",
          "enum": ["A+", "A", "B", "C", "invalid"]
        },
        "timing": { "type": "string" },
        "positioning": { "type": "string" }
      }
    },

    "alternatives": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["action", "reason"],
        "additionalProperties": false,
        "properties": {
          "action": {
            "type": "string",
            "enum": ["WAIT", "REDUCE_SIZE", "WATCH_BREAKOUT", "WATCH_PULLBACK"]
          },
          "reason": { "type": "string" }
        }
      }
    },

    "insights": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["type", "title", "body", "confidence"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["approval", "rejection", "risk", "timing", "execution"]
          },
          "title": { "type": "string" },
          "body": { "type": "string" },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    }
  }
}