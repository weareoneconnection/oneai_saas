{
  "$id": "executionPlanOutput",
  "type": "object",
  "required": ["reply", "executionBoundary", "actions", "handoffNotes", "risks"],
  "properties": {
    "reply": { "type": "string" },
    "executionBoundary": { "const": "plans_only" },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "action", "input", "verification", "dependsOn"],
        "properties": {
          "id": { "type": "string" },
          "action": { "type": "string" },
          "input": { "type": "object" },
          "verification": { "type": "string" },
          "dependsOn": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "handoffNotes": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "risks": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "rollbackPlan": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
