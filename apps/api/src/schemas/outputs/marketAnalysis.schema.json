{
  "$id": "marketAnalysisOutput",
  "type": "object",
  "required": ["marketState", "summary", "signals", "levels", "setup"],
  "additionalProperties": false,
  "properties": {
    "marketState": {
      "type": "object",
      "required": ["trend", "structure", "volatility", "bias", "confidence"],
      "additionalProperties": false,
      "properties": {
        "trend": {
          "type": "string",
          "enum": ["bullish", "bearish", "neutral", "mixed"]
        },
        "structure": {
          "type": "string"
        },
        "volatility": {
          "type": "string"
        },
        "bias": {
          "type": "string",
          "enum": ["long", "short", "wait"]
        },
        "confidence": {
          "type": "number"
        }
      }
    },

    "summary": {
      "type": "string",
      "minLength": 5
    },

    "signals": {
      "type": "object",
      "required": [
        "trendStrength",
        "momentum",
        "volumeCondition",
        "flowCondition",
        "riskCondition"
      ],
      "additionalProperties": false,
      "properties": {
        "trendStrength": { "type": "string" },
        "momentum": { "type": "string" },
        "volumeCondition": { "type": "string" },
        "flowCondition": { "type": "string" },
        "riskCondition": { "type": "string" }
      }
    },

    "levels": {
      "type": "object",
      "required": ["support", "resistance", "invalidation", "triggerZone"],
      "additionalProperties": false,
      "properties": {
        "support": {
          "type": "array",
          "minItems": 0,
          "items": { "type": "number" }
        },
        "resistance": {
          "type": "array",
          "minItems": 0,
          "items": { "type": "number" }
        },
        "invalidation": {
          "type": "number"
        },
        "triggerZone": {
          "type": "array",
          "minItems": 0,
          "maxItems": 2,
          "items": { "type": "number" }
        }
      }
    },

    "setup": {
      "type": "object",
      "required": [
        "type",
        "direction",
        "entryLogic",
        "stopLogic",
        "takeProfitLogic",
        "timeHorizon",
        "confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string"
        },
        "direction": {
          "type": "string",
          "enum": ["long", "short", "neutral"]
        },
        "entryLogic": {
          "type": "string"
        },
        "stopLogic": {
          "type": "string"
        },
        "takeProfitLogic": {
          "type": "string"
        },
        "timeHorizon": {
          "type": "string"
        },
        "confidence": {
          "type": "number"
        }
      }
    },

    "risks": {
      "type": "array",
      "minItems": 0,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["title", "body", "severity"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" },
          "body": { "type": "string" },
          "severity": { "type": "string" }
        }
      }
    },

    "insights": {
      "type": "array",
      "minItems": 0,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["type", "title", "body", "confidence"],
        "additionalProperties": false,
        "properties": {
          "type": { "type": "string" },
          "title": { "type": "string" },
          "body": { "type": "string" },
          "confidence": {
            "type": "number"
          }
        }
      }
    }
  }
}