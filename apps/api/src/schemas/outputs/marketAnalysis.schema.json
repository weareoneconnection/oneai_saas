{
  "$id": "marketAnalysisOutput",
  "type": "object",
  "required": ["marketState", "summary", "signals", "levels", "setup"],
  "additionalProperties": false,
  "properties": {
    "marketState": {
      "type": "object",
      "required": ["trend", "structure", "volatility", "bias", "confidence"],
      "additionalProperties": false,
      "properties": {
        "trend": {
          "type": "string",
          "enum": ["bullish", "bearish", "neutral", "mixed"]
        },
        "structure": {
          "type": "string",
          "enum": [
            "breakout",
            "trend_continuation",
            "range",
            "compression",
            "reversal_watch",
            "distribution",
            "accumulation"
          ]
        },
        "volatility": {
          "type": "string",
          "enum": ["low", "normal", "high", "expanding"]
        },
        "bias": {
          "type": "string",
          "enum": ["long", "short", "wait"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },

    "summary": {
      "type": "string",
      "minLength": 5
    },

    "signals": {
      "type": "object",
      "required": [
        "trendStrength",
        "momentum",
        "volumeCondition",
        "flowCondition",
        "riskCondition"
      ],
      "additionalProperties": false,
      "properties": {
        "trendStrength": {
          "type": "string",
          "enum": ["strong", "moderate", "weak"]
        },
        "momentum": {
          "type": "string",
          "enum": ["bullish", "bearish", "fading", "mixed"]
        },
        "volumeCondition": {
          "type": "string",
          "enum": ["supportive", "weak", "elevated", "abnormal"]
        },
        "flowCondition": {
          "type": "string",
          "enum": ["bullish", "bearish", "neutral", "mixed"]
        },
        "riskCondition": {
          "type": "string",
          "enum": ["low", "moderate", "high"]
        }
      }
    },

    "levels": {
      "type": "object",
      "required": ["support", "resistance", "invalidation", "triggerZone"],
      "additionalProperties": false,
      "properties": {
        "support": {
          "type": "array",
          "minItems": 0,
          "items": { "type": "number" }
        },
        "resistance": {
          "type": "array",
          "minItems": 0,
          "items": { "type": "number" }
        },
        "invalidation": {
          "type": "number"
        },
        "triggerZone": {
          "type": "array",
          "minItems": 0,
          "maxItems": 2,
          "items": { "type": "number" }
        }
      }
    },

    "setup": {
      "type": "object",
      "required": [
        "type",
        "direction",
        "entryLogic",
        "stopLogic",
        "takeProfitLogic",
        "timeHorizon",
        "confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "trend_follow",
            "breakout",
            "pullback",
            "mean_reversion",
            "early_trend",
            "no_trade"
          ]
        },
        "direction": {
          "type": "string",
          "enum": ["long", "short", "neutral"]
        },
        "entryLogic": {
          "type": "string",
          "minLength": 3
        },
        "stopLogic": {
          "type": "string",
          "minLength": 3
        },
        "takeProfitLogic": {
          "type": "string",
          "minLength": 3
        },
        "timeHorizon": {
          "type": "string",
          "enum": ["scalp", "intraday", "swing"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },

    "risks": {
      "type": "array",
      "minItems": 0,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["title", "body", "severity"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" },
          "body": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          }
        }
      }
    },

    "insights": {
      "type": "array",
      "minItems": 0,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["type", "title", "body", "confidence"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["structure", "momentum", "liquidity", "risk", "setup"]
          },
          "title": { "type": "string" },
          "body": { "type": "string" },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    }
  }
}