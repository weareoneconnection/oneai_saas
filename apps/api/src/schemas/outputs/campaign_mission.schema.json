{
  "$id": "campaignMissionOutput",
  "type": "object",
  "required": ["missionTitle", "objective", "audience", "steps", "proof", "reviewPolicy", "rewardPlan", "growthLoops", "risks"],
  "properties": {
    "missionTitle": { "type": "string" },
    "objective": { "type": "string" },
    "audience": { "type": "string" },
    "steps": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "proof": {
      "type": "object",
      "required": ["type", "instructions"],
      "properties": {
        "type": { "type": "string" },
        "instructions": { "type": "string" }
      },
      "additionalProperties": true
    },
    "reviewPolicy": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "rewardPlan": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "growthLoops": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "risks": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "recommendedCopy": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": true
}
