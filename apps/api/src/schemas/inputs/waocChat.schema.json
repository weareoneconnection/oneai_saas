{
  "$id": "waocChatInput",
  "type": "object",
  "additionalProperties": false,
  "required": ["message"],
  "properties": {
    "message": { "type": "string", "minLength": 1, "maxLength": 4000 },
    "context": {
      "type": "string",
      "enum": ["community", "mission", "philosophy", "general"],
      "default": "general"
    },
    "lang": { "type": "string", "enum": ["en", "zh"], "default": "en" }
  }
}