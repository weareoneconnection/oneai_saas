{
  "$id": "waocBrainInput",
  "type": "object",
  "additionalProperties": false,
  "required": ["platform", "resolvedLanguage"],
  "properties": {
    "communityId": {
      "type": "string",
      "minLength": 1
    },
    "communityName": {
      "type": "string",
      "minLength": 1
    },
    "communityType": {
      "type": "string",
      "enum": ["general", "builder", "social", "support", "announcement", "governance", "partner"]
    },
    "channelType": {
      "type": "string",
      "enum": ["group", "channel", "forum", "feed", "dm", "unknown"]
    },
    "platform": {
      "type": "string",
      "enum": ["telegram", "discord", "slack", "x", "web"]
    },
    "resolvedLanguage": {
      "type": "string",
      "enum": ["en", "zh", "mixed"]
    },
    "communityStage": {
      "type": "string",
      "enum": ["cold_start", "early_growth", "stable_engagement", "fatigue", "fragmented", "conflict", "mission_ready", "dormant"]
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "messageCount": { "type": "integer", "minimum": 0 },
        "activeUserCount": { "type": "integer", "minimum": 0 },
        "newMemberCount": { "type": "integer", "minimum": 0 },
        "builderDensity": { "type": "number", "minimum": 0, "maximum": 1 },
        "tensionLevel": { "type": "number", "minimum": 0, "maximum": 1 },
        "missionReadiness": { "type": "number", "minimum": 0, "maximum": 1 },
        "botExposureRisk": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "candidates": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "targetUserIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "integer" }
        },
        "silentCoreUserIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "integer" }
        },
        "topContributorUserIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "integer" }
        }
      }
    },
    "summaries": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "recentThreadSummary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 5000
        },
        "notableTopics": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        }
      }
    },
    "recentInterventions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action"],
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "stay_quiet",
              "welcome_new_member",
              "ask_open_question",
              "summarize_thread",
              "nudge_core_member",
              "connect_members",
              "launch_micro_mission",
              "amplify_builder_signal",
              "elevate_civilization_narrative",
              "cool_down_thread",
              "escalate_to_human"
            ]
          },
          "ts": { "type": "integer", "minimum": 0 },
          "outcome": { "type": "string", "minLength": 1, "maxLength": 100 },
          "dedupeKey": { "type": "string", "minLength": 1, "maxLength": 200 },
          "surface": {
            "type": "string",
            "enum": ["none", "public", "private", "human_review"]
          }
        }
      }
    },
    "riskContext": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "hasConflictRisk": { "type": "boolean" },
        "hasSafetyAmbiguity": { "type": "boolean" },
        "hasTrustRisk": { "type": "boolean" }
      }
    },
    "timeContext": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "windowLabel": { "type": "string", "minLength": 1, "maxLength": 100 },
        "recentWindowMs": { "type": "integer", "minimum": 0 },
        "comparisonWindowMs": { "type": "integer", "minimum": 0 }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    }
  }
}